<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal de Alumnos - Sully-Bec Instituto</title>
    
    <!-- Scripts Necesarios -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #FFF6F2; 
        }

        .durazno-bg { background-color: #FFF6F2; }
        .durazno-accent { background-color: #FEECE5; }
        .sully-bordo { color: #8B1D2D; }
        .sully-bg-bordo { background-color: #8B1D2D; }
        
        .animate-fade-in {
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Estilos para inputs */
        input:focus {
            box-shadow: 0 0 0 3px rgba(254, 236, 229, 0.5);
        }
    </style>
</head>
<body>

    <div id="app">
        <!-- El contenido se genera aquí mediante JavaScript -->
    </div>

    <script type="module">
        // Importación de Firebase desde CDN
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-app.js";
        import { getAuth, onAuthStateChanged, signInAnonymously, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-auth.js";
        import { getFirestore, doc, getDoc } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-firestore.js";

        // CONFIGURACIÓN DE FIREBASE (Reemplaza con tus datos si es necesario)
        const firebaseConfig = JSON.parse(window.__firebase_config || '{}');
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const appId = window.__app_id || 'sullybec-gestion-integral';

        const BRAND = {
            primary: '#8B1D2D',
            logoId: '1gjM8QJhfynpT0il86P3IRWwD_wMQWcCC',
            social: 'SullyBec.Instituto'
        };

        const logoUrl = `https://drive.google.com/thumbnail?id=${BRAND.logoId}&sz=w500`;

        // Estado de la aplicación
        let state = {
            isLoggedIn: false,
            studentData: null,
            activeTab: 'pagos',
            loading: true,
            loginError: ''
        };

        // Función para renderizar la interfaz
        function render() {
            const appDiv = document.getElementById('app');
            
            if (state.loading) {
                appDiv.innerHTML = `
                    <div class="h-screen flex items-center justify-center text-[#8B1D2D] font-bold animate-pulse text-[10px] tracking-[0.3em] uppercase">
                        Sully-Bec Instituto...
                    </div>
                `;
                return;
            }

            if (!state.isLoggedIn) {
                renderLogin(appDiv);
            } else {
                renderDashboard(appDiv);
            }
            
            // Inicializar iconos de Lucide después de renderizar
            lucide.createIcons();
        }

        function renderLogin(container) {
            container.innerHTML = `
                <div class="min-h-screen flex items-center justify-center p-6 animate-fade-in">
                    <div class="w-full max-w-md bg-white rounded-[3.5rem] p-12 shadow-2xl shadow-orange-200/30 border border-white text-center">
                        <div class="w-28 h-28 mx-auto mb-8 relative">
                            <div class="absolute inset-0 bg-[#FEECE5] rounded-full blur-xl opacity-50"></div>
                            <div class="relative w-full h-full bg-white rounded-full flex items-center justify-center overflow-hidden border-4 border-white shadow-lg">
                                <img src="${logoUrl}" alt="Logo" class="w-full h-full object-cover p-2" onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=SB'">
                            </div>
                        </div>
                        
                        <h1 class="text-xl font-black text-slate-800 mb-1 uppercase tracking-tighter">Bienvenido a</h1>
                        <h2 class="text-2xl font-black text-[#8B1D2D] mb-10 uppercase tracking-tight">Sullybec Instituto</h2>
                        
                        <form id="loginForm" class="space-y-4">
                            <div class="text-left">
                                <label class="text-[10px] font-black text-slate-400 uppercase ml-5 mb-1.5 block tracking-widest">ID de Expediente</label>
                                <input type="text" id="studentId" placeholder="Ingresa tu ID" class="w-full px-7 py-4 bg-[#FFF6F2] border border-orange-100 rounded-[1.5rem] outline-none font-bold text-slate-700">
                            </div>
                            <div class="text-left">
                                <label class="text-[10px] font-black text-slate-400 uppercase ml-5 mb-1.5 block tracking-widest">Contraseña</label>
                                <input type="password" id="password" placeholder="••••••••" class="w-full px-7 py-4 bg-[#FFF6F2] border border-orange-100 rounded-[1.5rem] outline-none font-bold text-slate-700">
                            </div>
                            
                            ${state.loginError ? `<div class="text-red-500 bg-red-50 p-4 rounded-2xl text-[10px] font-bold uppercase">${state.loginError}</div>` : ''}

                            <button type="submit" class="w-full bg-[#8B1D2D] text-white py-4.5 rounded-[1.5rem] font-black uppercase tracking-[0.2em] shadow-xl shadow-red-200/50 hover:brightness-110 active:scale-[0.98] transition-all mt-6 py-4">
                                Ingresar al Portal
                            </button>
                        </form>
                    </div>
                </div>
            `;

            document.getElementById('loginForm').onsubmit = handleLogin;
        }

        function renderDashboard(container) {
            container.innerHTML = `
                <div class="min-h-screen pb-20">
                    <header class="bg-white/90 backdrop-blur-xl border-b border-orange-50 sticky top-0 z-20">
                        <div class="max-w-4xl mx-auto px-6 py-4 flex justify-between items-center">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center border border-orange-50 overflow-hidden p-1">
                                    <img src="${logoUrl}" class="w-full h-full object-contain">
                                </div>
                                <div>
                                    <h1 class="text-sm font-black text-slate-800 uppercase tracking-tighter">Portal Académico</h1>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase mt-1">Sully-Bec Instituto</p>
                                </div>
                            </div>
                            <button id="logoutBtn" class="bg-[#FEECE5] text-[#8B1D2D] p-3 rounded-2xl">
                                <i data-lucide="log-out"></i>
                            </button>
                        </div>
                    </header>

                    <main class="max-w-4xl mx-auto p-6 space-y-6 animate-fade-in">
                        <section class="bg-white rounded-[3rem] p-10 text-slate-800 shadow-xl shadow-orange-200/10 border border-white relative overflow-hidden">
                            <div class="relative z-10 flex flex-col md:flex-row items-center gap-10 text-center md:text-left">
                                <div class="w-32 h-32 rounded-[2.5rem] bg-[#FEECE5] border-8 border-white shadow-lg flex items-center justify-center">
                                    <i data-lucide="user" class="text-[#8B1D2D] w-16 h-16"></i>
                                </div>
                                <div class="flex-1">
                                    <div class="inline-flex items-center gap-2 bg-[#FEECE5] px-4 py-1.5 rounded-full text-[10px] font-black text-[#8B1D2D] uppercase tracking-widest mb-3">
                                        <i data-lucide="graduation-cap" class="w-3 h-3"></i> Estudiante Activo
                                    </div>
                                    <h2 class="text-4xl font-black text-slate-800 leading-tight">${state.studentData.nombre}</h2>
                                    <p class="text-slate-400 font-bold uppercase text-xs tracking-[0.2em] mt-2">${state.studentData.curso || 'Diplomado Superior'}</p>
                                </div>
                            </div>
                        </section>

                        <div class="grid grid-cols-2 gap-3 bg-white p-2.5 rounded-[2rem] shadow-sm border border-orange-50">
                            <button onclick="changeTab('pagos')" class="py-4 rounded-[1.5rem] text-[10px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-3 ${state.activeTab === 'pagos' ? 'bg-[#8B1D2D] text-white shadow-lg' : 'text-slate-400'}">
                                <i data-lucide="receipt"></i> Mis Recibos
                            </button>
                            <button onclick="changeTab('clases')" class="py-4 rounded-[1.5rem] text-[10px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-3 ${state.activeTab === 'clases' ? 'bg-[#8B1D2D] text-white shadow-lg' : 'text-slate-400'}">
                                <i data-lucide="book-open"></i> Mis Clases
                            </button>
                        </div>

                        <div id="tabContent">
                            ${state.activeTab === 'pagos' ? renderPagos() : renderClases()}
                        </div>

                        <footer class="pt-16 text-center space-y-10">
                            <div class="flex justify-center gap-12 text-slate-400">
                                <div class="flex flex-col items-center gap-2"><i data-lucide="instagram"></i><span class="text-[9px] font-black uppercase">Instagram</span></div>
                                <div class="flex flex-col items-center gap-2"><i data-lucide="facebook"></i><span class="text-[9px] font-black uppercase">Facebook</span></div>
                                <div class="flex flex-col items-center gap-2"><i data-lucide="message-circle"></i><span class="text-[9px] font-black uppercase">Soporte</span></div>
                            </div>
                            <div class="text-[9px] font-black text-orange-200/80 uppercase tracking-[0.6em]">
                                Sully-Bec Instituto • 2026
                            </div>
                        </footer>
                    </main>
                </div>
            `;

            document.getElementById('logoutBtn').onclick = () => {
                state.isLoggedIn = false;
                state.studentData = null;
                render();
            };
        }

        function renderPagos() {
            return `
                <div class="bg-white rounded-[3rem] p-10 border border-orange-50 shadow-sm animate-fade-in">
                    <div class="flex items-center justify-between mb-10">
                        <h3 class="font-black text-slate-800 uppercase text-[11px] tracking-[0.2em] flex items-center gap-3">
                            <div class="w-2 h-2 bg-[#8B1D2D] rounded-full"></div> Documentos de Pago
                        </h3>
                    </div>
                    
                    <div class="p-8 border border-orange-50 rounded-[2.5rem] flex items-center justify-between bg-[#FFF6F2]/50">
                        <div class="flex items-center gap-6 text-slate-800">
                            <div class="bg-white p-5 rounded-2xl border border-orange-100 text-[#8B1D2D] shadow-sm"><i data-lucide="file-text"></i></div>
                            <div>
                                <p class="font-black text-base uppercase tracking-tighter leading-none">Comprobante de Inscripción</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase mt-2">Validez Académica • PDF</p>
                            </div>
                        </div>
                        <button class="bg-white text-[#8B1D2D] border-2 border-[#FEECE5] w-14 h-14 rounded-2xl flex items-center justify-center hover:bg-[#8B1D2D] hover:text-white transition-all">
                            <i data-lucide="download"></i>
                        </button>
                    </div>

                    <div class="mt-12 p-8 bg-[#FEECE5]/50 rounded-[2.5rem] border border-orange-100">
                        <div class="flex items-center gap-3 mb-4 text-[#8B1D2D]">
                            <i data-lucide="lock" class="w-4 h-4"></i>
                            <p class="text-[11px] font-black uppercase">Cláusula de Inscripción</p>
                        </div>
                        <p class="text-[11px] text-[#8B1D2D]/80 italic leading-relaxed font-semibold">
                            • <span class="font-black uppercase underline">No se realizan devoluciones</span> de pagos bajo ningún motivo.<br>
                            • El acceso a este portal es personal e intransferible.
                        </p>
                    </div>
                </div>
            `;
        }

        function renderClases() {
            return `
                <div class="bg-white rounded-[3.5rem] p-12 border border-orange-50 shadow-sm text-center animate-fade-in">
                    <div class="w-24 h-24 bg-[#FEECE5] rounded-[2.5rem] flex items-center justify-center mx-auto mb-8 text-[#8B1D2D]">
                        <i data-lucide="book-open" class="w-12 h-12"></i>
                    </div>
                    <h3 class="font-black text-slate-800 uppercase text-2xl mb-3 tracking-tighter">Material de Estudio</h3>
                    <p class="text-[11px] text-slate-400 mb-12 font-bold uppercase tracking-widest">Consulta las guías de tus módulos activos.</p>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="p-8 bg-[#FFF6F2]/70 border-2 border-dashed border-orange-100 rounded-[2.5rem] flex items-center gap-6">
                            <div class="bg-white p-4 rounded-xl text-[#8B1D2D] shadow-sm"><i data-lucide="file-text"></i></div>
                            <div class="text-left">
                                <p class="text-[11px] font-black uppercase text-slate-800">Guía de Bienvenida</p>
                                <p class="text-[10px] font-bold text-[#8B1D2D] mt-2">DESCARGAR PDF</p>
                            </div>
                        </div>
                        <div class="p-8 bg-slate-50 border-2 border-dashed border-slate-100 rounded-[2.5rem] flex items-center gap-6 opacity-40">
                            <div class="bg-white p-4 rounded-xl text-slate-300"><i data-lucide="lock"></i></div>
                            <div class="text-left"><p class="text-[11px] font-black uppercase text-slate-300">Próximamente</p></div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Manejadores de eventos
        async function handleLogin(e) {
            e.preventDefault();
            const id = document.getElementById('studentId').value;
            const pass = document.getElementById('password').value;
            
            if (!id || !pass) {
                state.loginError = 'Ingresa todos los datos';
                render();
                return;
            }

            try {
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'alumnos', id);
                const docSnap = await getDoc(docRef);

                if (docSnap.exists()) {
                    const data = docSnap.data();
                    if (data.password === pass) {
                        state.studentData = data;
                        state.isLoggedIn = true;
                        state.loginError = '';
                    } else {
                        state.loginError = 'Contraseña incorrecta';
                    }
                } else {
                    state.loginError = 'ID no encontrado';
                }
            } catch (err) {
                state.loginError = 'Error de conexión';
            }
            render();
        }

        window.changeTab = (tab) => {
            state.activeTab = tab;
            render();
        };

        // Inicio automático de sesión anónima para consultas
        const init = async () => {
            try {
                await signInAnonymously(auth);
                state.loading = false;
                render();
            } catch (e) {
                console.error(e);
            }
        };

        init();
    </script>
</body>
</html>
